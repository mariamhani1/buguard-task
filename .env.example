# ---- Database ----
# Postgres credentials (used by docker-compose to provision the db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=darkatlas_asm
# Connection string used by the API (matches the values above when using compose)
DATABASE_URL=postgresql+asyncpg://postgres:change-me-in-production@db:5432/darkatlas_asm

# ---- LLM (read from env, never commit a real key) ----
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# ---- Auth ----
# Comma-separated "apikey:org_id" pairs. The org a caller acts on is derived from
# their key server-side. If unset, built-in DEV keys are used (NOT for production):
#   dev-key-acme:org_acme , dev-key-globex:org_globex
API_KEYS=dev-key-acme:org_acme,dev-key-globex:org_globex

# ---- Tuning (optional) ----
AGENT_VERBOSE=false
ANALYZE_RATE_LIMIT_PER_MIN=30
EXPIRING_SOON_DAYS=30
MAX_IMPORT_BATCH=5000
